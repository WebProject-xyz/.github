{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "WebProject.xyz organisation renovate config",
  "platform": "github",
  "assignees": [
    "fahl-design"
  ],
  "extends": [
    ":dependencyDashboard",
    ":ignoreModulesAndTests",
    ":automergeMinor",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":enableVulnerabilityAlerts",
    ":timezone(UTC)",
    ":label(renovate)",
    "group:allNonMajor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":label(dependencies)",
    ":gitSignOff",
    ":semanticPrefixChore",
    ":semanticCommitTypeAll(chore)",
    "helpers:pinGitHubActionDigests"
  ],
  "rebaseWhen": "behind-base-branch",
  "automergeType": "pr",
  "commitBodyTable": true,
  "lockFileMaintenance": {
    "enabled": true,
    "extends": [
      "schedule:daily"
    ],
    "automerge": true
  },
  "platformAutomerge": true,
  "prFooter": "[Read more information](https://github.com/WebProject-xyz/.github/blob/main/RENOVATE.md) about the use of [Renovate Bot](https://github.com/renovatebot/renovate).",
  "rangeStrategy": "replace",
  "rollbackPrs": true,
  "pinDigests": true,
  "minimumReleaseAge": "3 days",
  "composer": {
    "composerIgnorePlatformReqs": false
  },
  "constraints": {
    "php": "~8.3.0 || ~8.4.0"
  },
  "packageRules": [
    {
      "description": "General automerge for minor and patch updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Group all GitHub Action updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group PHP development tools",
      "matchPackagePatterns": [
        "phpunit/",
        "phpstan/",
        "codeception/"
      ],
      "groupName": "PHP Dev Tools"
    },
    {
      "matchPackagePatterns": [
        "symfony/"
      ],
      "groupSlug": "symfony",
      "groupName": "Symfony Packages",
      "automerge": false,
      "extends": [
        ":label(Awaiting Maintainer Response)"
      ]
    },
    {
      "matchDepNames": [
        "php"
      ],
      "allowedVersions": "~8.3.0 || ~8.4.0",
      "automerge": false,
      "ignoreUnstable": false,
      "groupName": "PHP",
      "extends": [
        ":label(Awaiting Maintainer Response)"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "versioning": "semver"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "extends": [
      ":automergeDisabled",
      ":automergePr",
      ":labels(security)"
    ],
    "rangeStrategy": "bump"
  }
}
